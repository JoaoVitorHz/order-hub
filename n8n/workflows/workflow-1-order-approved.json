    "Formatar Mensagem": {
      "main": [
        [
          { "node": "Enviar Notificação (webhook.site / Slack / Discord)", "type": "main", "index": 0 },
          { "node": "Registrar no Google Sheets (via webhook.site mock)", "type": "main", "index": 0 }
        ]
      ]
    },
    "Enviar Notificação (webhook.site / Slack / Discord)": {
